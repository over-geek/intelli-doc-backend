INTELLIDOC_KEY_VAULT_ENABLED=false
APPLICATIONINSIGHTS_ENABLED=false
INTELLIDOC_REDIS_ENABLED=false
INTELLIDOC_INGESTION_ENABLED=false
INTELLIDOC_INGESTION_WORKER_ENABLED=false
INTELLIDOC_DOCUMENT_INTELLIGENCE_ENABLED=false
INTELLIDOC_EMBEDDING_ENABLED=true
INTELLIDOC_EMBEDDING_BATCH_SIZE=16
INTELLIDOC_EMBEDDING_MAX_RETRIES=3

DATASOURCE_URL=jdbc:postgresql://localhost:5432/intellidoc_db
DATASOURCE_USERNAME=postgres
DATASOURCE_PASSWORD=postgres

ENTRA_ISSUER_URI=https://login.microsoftonline.com/<tenant-id>/v2.0
ENTRA_JWK_SET_URI=https://login.microsoftonline.com/<tenant-id>/discovery/v2.0/keys

OPENAI_ENDPOINT=https://oai-intellidoc.openai.azure.com/
OPENAI_API_KEY=<azure-openai-api-key>

SERVICEBUS_CONNECTION_STRING=Endpoint=sb://<namespace>.servicebus.windows.net/;SharedAccessKeyName=<policy>;SharedAccessKey=<key>
servicebus-ingestion-queue=ingestion-queue
DOCUMENT_INTELLIGENCE_ENDPOINT=https://<document-intelligence-name>.cognitiveservices.azure.com/
DOCUMENT_INTELLIGENCE_API_KEY=<document-intelligence-api-key>
DOCUMENT_INTELLIGENCE_MODEL_ID=prebuilt-layout
